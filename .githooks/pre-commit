#!/bin/sh

# Ensure formatting is correct
echo "Checking cargo fmt..."
cargo fmt --all -- --check
if [ $? -ne 0 ]; then
    echo "❌ cargo fmt failed! Please format your code using 'cargo fmt'."
    exit 1
fi

# (Optional) You can add other lightweight checks here

echo "✅ All pre-commit checks passed!"
exit 0
