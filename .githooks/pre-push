#!/bin/sh

# Add cargo to PATH for GUI clients
export PATH="$HOME/.cargo/bin:$PATH"

echo "Running pre-push checks..."

# Ensure formatting is correct (double check)
echo "Checking cargo fmt..."
if ! cargo fmt --all -- --check; then
    echo "❌ cargo fmt failed! Please format your code before pushing."
    exit 1
fi

# Run clippy to catch common mistakes before code leaves the machine
echo "Checking cargo clippy..."
if ! cargo clippy --workspace --all-targets --all-features -- -D warnings; then
    echo "❌ cargo clippy failed! Please fix the warnings before pushing."
    exit 1
fi

echo "✅ All pre-push checks passed! Pushing code..."
exit 0
