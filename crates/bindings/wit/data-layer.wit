package syneroym:data-layer@0.1.0;

interface store {
    enum index-type {
        %string,
        numeric,
        boolean,
    }

    record index-definition {
        field-name: string,
        %type: index-type,
    }

    record collection-schema {
        name: string,
        indexes: list<index-definition>,
    }

    record record-write-value {
        id: string,
        payload: list<u8>,
    }

    record record-read-value {
        id: string,
        payload: list<u8>,
        creator-id: string,
        created-at: u64,
        updated-at: u64,
    }

    record query-options {
        filter: option<string>,
        limit: option<u32>,
        cursor: option<string>,
    }

    record query-result {
        records: list<record-read-value>,
        next-cursor: option<string>,
    }

    record patch-mutation {
        id: string,
        patch-json: list<u8>,
    }

    variant mutation {
        put(record-write-value),
        patch(patch-mutation),
        delete(string),
    }

    variant data-layer-error {
        permission-denied,
        collection-not-found,
        schema-violation(string),
        quota-exceeded,
        internal(string),
    }

    create-collection: func(schema: collection-schema) -> result<_, data-layer-error>;

    drop-collection: func(name: string) -> result<_, data-layer-error>;

    put: func(collection: string, value: record-write-value) -> result<_, data-layer-error>;

    patch: func(collection: string, id: string, patch-json: list<u8>) -> result<_, data-layer-error>;

    get: func(collection: string, id: string) -> result<option<record-read-value>, data-layer-error>;

    /// Queries records in a collection.
    ///
    /// NOTE: The host implementation must enforce a hard upper bound on the number
    /// of returned records (e.g. max 1000 per page) to prevent memory exhaustion,
    /// regardless of the limit specified in query options.
    query: func(collection: string, opts: query-options) -> result<query-result, data-layer-error>;

    delete: func(collection: string, id: string) -> result<_, data-layer-error>;

    delete-many: func(collection: string, filter: string) -> result<u64, data-layer-error>;

    /// Mutates multiple records in a single transaction.
    ///
    /// NOTE: The host must enforce a strict MAX_BATCH_SIZE limit on the number of
    /// mutations to prevent starvation of the single-writer SQLite database.
    batch-mutate: func(collection: string, mutations: list<mutation>) -> result<_, data-layer-error>;

    /// Executes arbitrary DDL statements.
    ///
    /// SECURITY: The host must strictly validate that the caller is in an init or
    /// migration context (e.g., HostState.is_init_context == true) and reject execution
    /// in standard runtime contexts.
    execute-ddl: func(sql: string) -> result<_, data-layer-error>;
}

world data-layer-guest {
    import store;

    export init: func() -> result<_, string>;
    export migrate: func() -> result<_, string>;
}
