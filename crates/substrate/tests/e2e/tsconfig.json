{
    "compilerOptions": {
        "target": "ES2021",
        "module": "Node16",
        "moduleResolution": "node16",
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ES2021"
        ],
        "types": [
            "node",
            "@playwright/test"
        ],
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": [
        "tests/**/*.ts",
        "*.ts"
    ]
}