{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syneroym.xyz/schema/fdae-v1.json",
  "title": "FDAE policy document (fdae/v1)",
  "type": "object",
  "required": ["version", "definitions"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": "fdae/v1" },
    "strict": { "type": "boolean" },
    "definitions": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/definition" }
    }
  },
  "$defs": {
    "sql_identifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "definition": {
      "type": "object",
      "required": ["table"],
      "additionalProperties": false,
      "properties": {
        "table": { "$ref": "#/$defs/sql_identifier" },
        "principal_column": { "$ref": "#/$defs/sql_identifier" },
        "relations": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/relation" }
        },
        "permissions": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/permission" }
        },
        "default": { "type": "string", "minLength": 1 },
        "resolvable_without_capability": { "type": "boolean" }
      }
    },
    "relation": {
      "type": "object",
      "required": ["target"],
      "additionalProperties": false,
      "properties": {
        "target": { "type": "string", "minLength": 1 },
        "service": { "type": "string", "minLength": 1 },
        "join_column": { "$ref": "#/$defs/sql_identifier" },
        "from_key": { "$ref": "#/$defs/sql_identifier" },
        "to_key": { "$ref": "#/$defs/sql_identifier" },
        "recursive": { "type": "boolean" }
      }
    },
    "permission": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allows": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "operator": {
          "type": "string",
          "enum": ["union", "intersection", "exclusion"]
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1,
            "maxItems": 33
          }
        },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" }
        },
        "includes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fields": { "$ref": "#/$defs/fields_policy" }
      }
    },
    "condition": {
      "type": "object",
      "required": ["column", "claim"],
      "additionalProperties": false,
      "properties": {
        "column": { "$ref": "#/$defs/sql_identifier" },
        "claim": { "type": "string", "minLength": 1 },
        "op": {
          "type": "string",
          "enum": ["eq", "ne", "gt", "gte", "lt", "lte"]
        }
      }
    },
    "fields_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "deny": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
