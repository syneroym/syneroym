package syneroym:core;

interface substrate {
    use identity.{node-id};

    record node-status {
        node-id: node-id,
        uptime-seconds: u64,
        is-online: bool,
    }

    /// Get the operational status of the substrate
    get-status: func() -> result<node-status, string>;

    /// Connect to a bootstrap server to get a relay assignment
    bootstrap-connect: func(bootstrap-url: string) -> result<string, string>;
}