{
    "sandbox": {
        "enabled": true,
        "autoAllowBashIfSandboxed": true,
        "excludedCommands": [
            "git"
        ]
    },
    "permissions": {
        "deny": [
            "Read(.env*)",
            "Bash(rm -rf*)",
            "Bash(sudo:*)",
            "Bash(curl:*)"
        ]
    }
}